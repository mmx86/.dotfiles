"""
" Temporary
"""

" camel case
nmap <leader>zq :%s/LabelStudios/ApiKeys/g<CR>
nmap <leader>zw :%s/LabelStudio/ApiKey/g<CR>
" case
nmap <leader>ze :%s/labelStudios/apiKeys/g<CR>
nmap <leader>zr :%s/labelStudio/apiKey/g<CR>
" snake case
nmap <leader>zt :%s/label_studios/api_keys/g<CR>
nmap <leader>zy :%s/label_studio/api_key/g<CR>
" kebab case
nmap <leader>zu :%s/label-studios/api-keys/g<CR>
nmap <leader>zo :%s/label-studio/api-key/g<CR>
" other
nmap <leader>zi :%s/LABEL_STUDIO/API_KEY/g<CR>
nmap <leader>zz <leader>zq<leader>zw<leader>ze<leader>zr<leader>zt<leader>zy<leader>zu<leader>zi
