:set relativenumber
:set number 

" Set leader to space.
let mapleader = " "


"""
" IDEA specific
"""

" Handle ideavim config.
nnoremap <leader>ve :e ~/.ideavimrc<CR>
nnoremap <leader>vr :source ~/.ideavimrc<CR>

nmap <leader>? :action GotoAction<CR>


"" MARKS
"" Only global marks are shown as bookmarks in pycharm. Make all marks global :E
"nnoremap ma mA
"nnoremap mb mB
